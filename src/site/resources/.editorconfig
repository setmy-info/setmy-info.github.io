root = true

[*]
charset = utf-8
indent_size = 4
indent_style = space
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[Makefile]
indent_style = tab

[*.ts]
quote_type = single

[*.cmd]
end_of_line = crlf

[*.md]
max_line_length = off
trim_trailing_whitespace = false

[*.{ex,exs}]
indent_style = space
indent_size = 2
